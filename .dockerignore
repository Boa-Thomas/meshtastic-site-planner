.playwright-mcp
__pycache__
*.pyc
.env
.gitignore

# Local build artefacts. app/ui is generated by Stage 1 of the Dockerfile
# (frontend-builder), so we don't want the host's local copy to pollute the
# image — the COPY --from=frontend-builder overlays it anyway, but excluding
# it here keeps the build context lean and avoids cache invalidation when a
# developer rebuilds the frontend locally.
.cache
.pytest_cache
.mypy_cache
.coverage
coverage
htmlcov
app/ui

# Test/CI scratch
*.log
*.local
.DS_Store

# Cached/persisted data
.splat_tiles
app/data
