# =============================================================================
# Meshtastic Site Planner — Environment Configuration
# Copy this file to .env and adjust as needed.
# =============================================================================

# --- Worker Scaling -----------------------------------------------------------

# Initial worker replicas (used by docker compose deploy.replicas)
CELERY_LIGHT_WORKERS=2
CELERY_HEAVY_WORKERS=1

# Memory limits per worker container
WORKER_LIGHT_MEM=4G
WORKER_HEAVY_MEM=8G

# --- Autoscaler ---------------------------------------------------------------

# Min/max worker counts managed by the autoscaler
MIN_LIGHT_WORKERS=1
MAX_LIGHT_WORKERS=4
MIN_HEAVY_WORKERS=1
MAX_HEAVY_WORKERS=3

# Seconds of empty queue before scaling down to minimums
SCALE_DOWN_DELAY=120

# How often (seconds) the autoscaler checks queue depth
CHECK_INTERVAL=10

# Docker Compose project name (used to find containers by label)
COMPOSE_PROJECT_NAME=meshtastic-site-planner

# --- Simulation Limits --------------------------------------------------------

# Radius (km) above which simulations go to the heavy queue
HEAVY_RADIUS_THRESHOLD_KM=200

# Hard cap on simulation radius (km). SPLAT! compiled with MAXPAGES=225
# supports up to ~810 km at equator, ~600 km at lat 50.
MAX_SIMULATION_RADIUS_KM=600

# --- Application --------------------------------------------------------------

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,https://site.meshtastic.org

# Virtual host for nginx-proxy + Let's Encrypt
VIRTUAL_HOST=site.meshtastic.org
LETSENCRYPT_HOST=site.meshtastic.org
