# =============================================================================
# Meshtastic Site Planner — Environment Configuration
# Copy this file to .env and adjust as needed.
# =============================================================================

# --- Worker Scaling -----------------------------------------------------------

# Initial worker replicas (used by docker compose deploy.replicas)
CELERY_LIGHT_WORKERS=2
CELERY_HEAVY_WORKERS=1

# Memory limits per worker container
WORKER_LIGHT_MEM=4G
WORKER_HEAVY_MEM=8G

# --- Autoscaler ---------------------------------------------------------------

# Min/max worker counts managed by the autoscaler
MIN_LIGHT_WORKERS=1
MAX_LIGHT_WORKERS=4
MIN_HEAVY_WORKERS=1
MAX_HEAVY_WORKERS=3

# Seconds of empty queue before scaling down to minimums
SCALE_DOWN_DELAY=120

# How often (seconds) the autoscaler checks queue depth
CHECK_INTERVAL=10

# Docker Compose project name (used to find containers by label)
COMPOSE_PROJECT_NAME=meshtastic-site-planner

# --- Simulation Limits --------------------------------------------------------

# Radius (km) above which simulations go to the heavy queue
HEAVY_RADIUS_THRESHOLD_KM=200

# Hard cap on simulation radius (km). SPLAT! compiled with MAXPAGES=225
# supports up to ~810 km at equator, ~600 km at lat 50.
MAX_SIMULATION_RADIUS_KM=600

# --- Application --------------------------------------------------------------

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,https://site.meshtastic.org

# Virtual host for nginx-proxy + Let's Encrypt
VIRTUAL_HOST=site.meshtastic.org
LETSENCRYPT_HOST=site.meshtastic.org

# --- Terrain (DEM) Source -----------------------------------------------------
# Selects which elevation dataset SPLAT! reads from. All three formats are
# transcoded to SRTM-compatible .hgt.gz internally so the rest of the pipeline
# is unchanged.
#
#   srtm        NASA SRTM 1-arcsec (default, public AWS bucket)
#   copernicus  Copernicus GLO-30 DSM (public AWS Open Data, ~30 m)
#   fabdem      FABDEM v1.2 DTM (canopy/buildings removed). CC BY-NC-SA —
#               no public mirror; you must host your own bucket.
DEM_SOURCE=srtm

# FABDEM mirror configuration (only relevant when DEM_SOURCE=fabdem).
# FABDEM_FALLBACK_SOURCE is used per-tile when a tile is missing in your mirror.
FABDEM_BUCKET=
FABDEM_PREFIX=
FABDEM_FALLBACK_SOURCE=copernicus
FABDEM_FILENAME_TEMPLATE={ns}{lat:02d}{ew}{lon:03d}_FABDEM_V1-2.tif

# --- Spatial Clutter (canopy / vegetation height) -----------------------------
# When set, SPLAT! sees synthetic terrain = DTM + canopy_height * factor, so
# vegetation is treated as terrain instead of via the uniform `-gc` knob.
#
#   none       Disabled (default — uses single-value clutter_height per request)
#   lang2023   ETH Global Canopy Height 10 m (Lang et al. 2023)
#   mapbiomas  MapBiomas Brazil annual vegetation height (BR-only)
#   custom     Operator-defined dataset
CLUTTER_SOURCE=none
CLUTTER_BUCKET=
CLUTTER_PREFIX=
CLUTTER_FILENAME_TEMPLATE=

# Penetration factor: 0.0 = trees invisible, 1.0 = solid wall.
# Default 0.6 is a placeholder — calibrate against field RSSI before relying
# on it. See utils/calibrate_clutter.py.
CLUTTER_PENETRATION_FACTOR=0.6

# Set to "true" once the factor above has been fitted against measurements.
# When false, the UI shows an "uncalibrated default" warning.
CLUTTER_FACTOR_CALIBRATED=false
CLUTTER_CALIBRATION_NOTES=
